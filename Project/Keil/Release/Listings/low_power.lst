 127          // wake up timer 中断服务函数
 128          void WUT_IRQHandler(void) interrupt WUT_IRQn
 129          {
 130   1          // 进入中断设置IP，不可删除
 131   1          __IRQnIPnPush(WUT_IRQn);
 132   1      
 133   1          // ---------------- 用户函数处理 -------------------
 134   1      
 135   1          // 周期中断
 136   1          if (WUT_CONH & TMR_PRD_PND(0x1))
 137   1          {
 138   2              WUT_CONH |= TMR_PRD_PND(0x1); // 清除pending
 139   2          }
 140   1      
 141   1          // 退出中断设置IP，不可删除
 142   1          __IRQnIPnPop(WUT_IRQn);
 143   1      }


