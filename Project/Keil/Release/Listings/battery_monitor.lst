                      LED_50_PERCENT_OFF();
                  }
              
                  if (stable_bat_percent >= 75)
                  {
                      LED_75_PERCENT_ON();
                  }
                  else
                  {
                      LED_75_PERCENT_OFF();
                  }
              
                  if (stable_bat_percent >= 100)
                  {
                      LED_100_PERCENT_ON();
                  }
                  else
                  {
                      LED_100_PERCENT_OFF();
                  }
              #endif
 356   1      }
