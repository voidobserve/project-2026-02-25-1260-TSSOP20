  31   1          // 周期中断
  32   1          if (TMR1_CONH & TMR_PRD_PND(0x1))
  33   1          {
  34   2              TMR1_CONH |= TMR_PRD_PND(0x1); // 清除pending
  35   2              // USER_DEBUG_PIN_TOGGLE();
  36   2              detect_1khz_signal_100us(); // 新增：每100us调用一次1KHz信号检测函数
  37   2          }
  38   1      
  39   1          // 退出中断设置IP，不可删除
  40   1          __IRQnIPnPop(TMR1_IRQn);
