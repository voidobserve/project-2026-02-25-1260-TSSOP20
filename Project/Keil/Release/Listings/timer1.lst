  26          // 定时器TMR0中断服务函数
  27          void TIMR1_IRQHandler(void) interrupt TMR1_IRQn
  28          {
  29   1          // 进入中断设置IP，不可删除
  30   1          __IRQnIPnPush(TMR1_IRQn);
  31   1      
  32   1          // ---------------- 用户函数处理 -------------------
  33   1          // 周期中断
  34   1          if (TMR1_CONH & TMR_PRD_PND(0x1))
  35   1          {
  36   2              TMR1_CONH |= TMR_PRD_PND(0x1); // 清除pending 
  37   2      
  38   2              
  39   2              detect_1khz_signal_100us(); // 新增：每100us调用一次1KHz信号检测函数
  40   2          }
  41   1      
  42   1          // 退出中断设置IP，不可删除
  43   1          __IRQnIPnPop(TMR1_IRQn);
