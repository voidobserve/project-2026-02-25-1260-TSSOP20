  17   1          TMR1_PRL = TMR_PERIOD_VAL_L((PEROID_VAL >> 0) & 0xFF);
  18   1          TMR1_CONH = TMR_PRD_PND(0x1) | TMR_PRD_IRQ_EN(0x1); // 计数等于周期时允许发生中断
  19   1          TMR1_CONL = TMR_SOURCE_SEL(0x7) |                   // 选择系统时钟
