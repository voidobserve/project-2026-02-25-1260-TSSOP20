   3          
   4          #define PEROID_VAL (SYSCLK / 1 / 10000 - 1) // 周期值=系统时钟/分频/频率 - 1
   5          
   6          /**
   7           * @brief 配置定时器 TMR 1
   8           */
   9          void timer1_init(void)
  10          {
  11   1      #if 1
  12   1          __EnableIRQ(TMR1_IRQn); // 使能 中断
  13   1          IE_EA = 1;              // 使能总中断
