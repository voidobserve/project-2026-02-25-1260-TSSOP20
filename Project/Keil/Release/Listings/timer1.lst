  24          // 定时器TMR0中断服务函数
  25          void TIMR1_IRQHandler(void) interrupt TMR1_IRQn
  26          {
  27   1          // 进入中断设置IP，不可删除
  28   1          __IRQnIPnPush(TMR1_IRQn);
  29   1      
