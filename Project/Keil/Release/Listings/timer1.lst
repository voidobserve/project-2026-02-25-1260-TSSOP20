   1          #include "timer1.h"
   2          #include "user_include.h"
   3          
   4          #define PEROID_VAL (SYSCLK / 1 / 10000 - 1) // 周期值=系统时钟/分频/频率 - 1
   5          
   6          /**
   7           * @brief 配置定时器 TMR 1
   8           */
   9          void timer1_init(void)
  10          {
  11   1          __EnableIRQ(TMR1_IRQn); // 使能 中断
  12   1          IE_EA = 1;              // 使能总中断
  13   1      
  14   1          TMR_ALLCON = TMR1_CNT_CLR(0x1);                        // 清除计数值
  15   1          TMR1_PRH = TMR_PERIOD_VAL_H((PEROID_VAL >> 8) & 0xFF); // 周期值
  16   1          TMR1_PRL = TMR_PERIOD_VAL_L((PEROID_VAL >> 0) & 0xFF);
  17   1          TMR1_CONH = TMR_PRD_PND(0x1) | TMR_PRD_IRQ_EN(0x1); // 计数等于周期时允许发生中断
  18   1          TMR1_CONL = TMR_SOURCE_SEL(0x7) |                   // 选择系统时钟
  19   1                      TMR_PRESCALE_SEL(0x00) |                // 预分频为1
  20   1                      TMR_MODE_SEL(0x1);                      // 计数模式
  21   1      }
